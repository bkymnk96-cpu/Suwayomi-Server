<%- include('partials/header') %>
<%- include('partials/sidebar', { activeTab: 'welcome' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-handshake"></i> الترحيب والمغادرة</h1>
        <p>قم بالترحيب بالأعضاء الجدد تلقائياً برسائل نصية أو بطاقات ترحيبية بصور مخصصة</p>
    </div>

    <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= req.query.success %></div>
    <% } %>

    <form action="/dashboard/<%= guild.id %>/welcome" method="POST" class="settings-form">

        <!-- Core Welcome Settings -->
        <div class="glass-panel reveal">
            <div class="section-title"><i class="fa-solid fa-sliders"></i> الإعدادات الأساسية</div>
            
            <div class="grid-form-2">
                <div class="form-group">
                    <label for="enabled">تفعيل نظام الترحيب</label>
                    <select id="enabled" name="enabled" class="glass-input">
                        <option value="1" <%= settings.enabled === 1 ? 'selected' : '' %>>🟢 مفعّل</option>
                        <option value="0" <%= settings.enabled === 0 ? 'selected' : '' %>>🔴 معطّل</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="channel">قناة الترحيب والتهنئة</label>
                    <select id="channel" name="channel" class="glass-input">
                        <option value="" <%= !settings.channel ? 'selected' : '' %>>تعطيل / بدون إرسال</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

            </div>

            <div class="form-group">
                <label for="message">رسالة الترحيب النصية</label>
                <textarea id="message" name="message" class="glass-input" rows="3" placeholder="اكتب رسالة الترحيب هنا..."><%= settings.message %></textarea>
                <small>المتغيرات المدعومة: <code>{user}</code> لذكر العضو، <code>{server}</code> لاسم السيرفر، <code>{membercount}</code> لعدد الأعضاء</small>
            </div>
        </div>

        <!-- Welcome Image Settings -->
        <div class="glass-panel reveal" style="animation-delay: 0.05s;">
            <div class="section-title"><i class="fa-solid fa-image"></i> بطاقة وصورة الترحيب المخصصة</div>

            <div class="form-group">
                <label for="image_url">رابط صورة الخلفية (Background Image URL)</label>
                <div class="d-flex gap-2">
                    <input type="text" id="image_url" name="image_url" class="glass-input flex-grow-1" value="<%= settings.image_url || '' %>" placeholder="https://example.com/background.png">
                    <input type="file" id="bg_upload" accept="image/*" style="display: none;">
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('bg_upload').click()"><i class="fa-solid fa-upload"></i> رفع ملف</button>
                </div>
                <small id="upload_status" class="text-muted mt-1">اتركه فارغاً في حال أردت استخدام الترحيب النصي فقط بدون صورة بطاقة</small>
            </div>

            <div class="grid-form-3 mt-2">
                <div class="form-group">
                    <label for="avatar_x">موقع الأفتار X (أفقي)</label>
                    <input type="number" id="avatar_x" name="avatar_x" class="glass-input" value="<%= settings.avatar_x || 100 %>">
                </div>
                <div class="form-group">
                    <label for="avatar_y">موقع الأفتار Y (رأسي)</label>
                    <input type="number" id="avatar_y" name="avatar_y" class="glass-input" value="<%= settings.avatar_y || 100 %>">
                </div>
                <div class="form-group">
                    <label for="avatar_size">حجم الأفتار (Avatar Size)</label>
                    <input type="number" id="avatar_size" name="avatar_size" class="glass-input" value="<%= settings.avatar_size || 150 %>">
                </div>
            </div>

            <div class="grid-form-2">
                <div class="form-group">
                    <label for="username_x">موقع اسم المستخدم X</label>
                    <input type="number" id="username_x" name="username_x" class="glass-input" value="<%= settings.username_x || 100 %>">
                </div>
                <div class="form-group">
                    <label for="username_y">موقع اسم المستخدم Y</label>
                    <input type="number" id="username_y" name="username_y" class="glass-input" value="<%= settings.username_y || 300 %>">
                </div>
            </div>

            <div class="grid-form-2">
                <div class="form-group">
                    <label for="username_color">لون خط الاسم</label>
                    <input type="color" id="username_color" name="username_color" class="glass-input" value="<%= settings.username_color || '#ffffff' %>" style="height: 40px; padding: 4px; cursor: pointer;">
                </div>
                <div class="form-group">
                    <label for="username_size">حجم خط الاسم</label>
                    <input type="number" id="username_size" name="username_size" class="glass-input" value="<%= settings.username_size || 40 %>">
                </div>
            </div>
        </div>

        <!-- Live Preview -->
        <div class="glass-panel reveal" style="animation-delay: 0.1s;">
            <div class="section-title"><i class="fa-solid fa-eye"></i> معاينة مباشرة وتعديل تفاعلي</div>
            <p class="text-muted mb-2">يمكنك تحريك صورة الأفتار والاسم يدوياً بالسحب بالفأرة مباشرة داخل اللوحة أدناه</p>

            <style>
                @font-face {
                    font-family: 'CustomFont';
                    src: url('/fonts/font.ttf') format('truetype');
                }
            </style>
            
            <div class="canvas-workspace">
                <div id="preview-container" class="preview-container greet-canvas-container" style="border: 1px solid var(--border); border-radius: var(--r-md); background: #080808;">
                    <div id="preview-avatar" class="preview-avatar" style="border: 2px solid #fff;">
                        <i class="fa-solid fa-user" style="font-size: 3rem; color: rgba(255,255,255,0.4);"></i>
                    </div>
                    <div id="preview-username" class="preview-username" style="font-family: 'CustomFont', sans-serif;">
                        Username
                    </div>
                </div>
            </div>


            <button type="submit" class="btn btn-primary mt-3 btn-large"><i class="fa-solid fa-floppy-disk"></i> حفظ كافة التغييرات</button>
        </div>

    </form>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const bgInput = document.getElementById('image_url');
        const container = document.getElementById('preview-container');

        const avatarEl = document.getElementById('preview-avatar');
        const axInput = document.getElementById('avatar_x');
        const ayInput = document.getElementById('avatar_y');
        const asizeInput = document.getElementById('avatar_size');

        const usernameEl = document.getElementById('preview-username');
        const uxInput = document.getElementById('username_x');
        const uyInput = document.getElementById('username_y');
        const ucolorInput = document.getElementById('username_color');
        const usizeInput = document.getElementById('username_size');

        let bgNativeWidth = 800;
        let bgNativeHeight = 400;

        function updateBackground() {
            const url = bgInput.value.trim();
            if (url) {
                container.style.backgroundImage = `url('${url}')`;
                const img = new Image();
                img.onload = function() {
                    bgNativeWidth = this.width;
                    bgNativeHeight = this.height;

                    const containerWidth = container.clientWidth;
                    const aspect = this.height / this.width;
                    container.style.height = (containerWidth * aspect) + 'px';

                    updatePositions();
                };
                img.src = url;
            } else {
                container.style.backgroundImage = 'none';
                container.style.height = '400px';
                bgNativeWidth = container.clientWidth || 800;
                bgNativeHeight = 400;
                updatePositions();
            }
        }

        function getScale() {
            const cw = container.clientWidth;
            return cw / bgNativeWidth;
        }

        function updatePositions() {
            const scale = getScale();

            const ax = parseInt(axInput.value) || 0;
            const ay = parseInt(ayInput.value) || 0;
            const asize = parseInt(asizeInput.value) || 150;

            avatarEl.style.left = (ax * scale) + 'px';
            avatarEl.style.top = (ay * scale) + 'px';
            avatarEl.style.width = (asize * scale) + 'px';
            avatarEl.style.height = (asize * scale) + 'px';

            const icon = avatarEl.querySelector('i');
            if (icon) icon.style.fontSize = Math.max(10, (asize * scale * 0.4)) + 'px';

            const ux = parseInt(uxInput.value) || 0;
            const uy = parseInt(uyInput.value) || 0;
            const usize = parseInt(usizeInput.value) || 40;

            usernameEl.style.left = (ux * scale) + 'px';
            usernameEl.style.top = (uy * scale - (usize * scale)) + 'px';
            usernameEl.style.color = ucolorInput.value || '#ffffff';
            usernameEl.style.fontSize = (usize * scale) + 'px';
        }

        function makeDraggable(el, xInput, yInput, isUsername = false) {
            let isDragging = false;
            let startX, startY, initialX, initialY;

            el.addEventListener('mousedown', (e) => {
                isDragging = true;
                startX = e.clientX;
                startY = e.clientY;
                initialX = parseInt(xInput.value) || 0;
                initialY = parseInt(yInput.value) || 0;
                e.preventDefault();
            });

            document.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                const scale = getScale();

                const dx = (e.clientX - startX) / scale;
                const dy = (e.clientY - startY) / scale;

                xInput.value = Math.round(initialX + dx);
                yInput.value = Math.round(initialY + dy);

                updatePositions();
            });

            document.addEventListener('mouseup', () => {
                isDragging = false;
            });
        }

        bgInput.addEventListener('input', updateBackground);

        [axInput, ayInput, asizeInput, uxInput, uyInput, ucolorInput, usizeInput].forEach(inp => {
            inp.addEventListener('input', updatePositions);
        });

        window.addEventListener('resize', () => {
            updateBackground();
        });

        makeDraggable(avatarEl, axInput, ayInput);
        makeDraggable(usernameEl, uxInput, uyInput, true);

        const bgUpload = document.getElementById('bg_upload');
        const uploadStatus = document.getElementById('upload_status');

        if (bgUpload) {
            bgUpload.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                uploadStatus.textContent = 'جاري الرفع...';
                uploadStatus.style.color = '#ffb000';
                
                const reader = new FileReader();
                reader.onload = async (ev) => {
                    const base64 = ev.target.result;
                    try {
                        const res = await fetch('/dashboard/<%= guild.id %>/welcome/upload', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ image: base64 })
                        });
                        const data = await res.json();
                        if (data.success) {
                            bgInput.value = data.url;
                            updateBackground();
                            uploadStatus.textContent = 'تم رفع الصورة بنجاح! يرجى حفظ الإعدادات لتطبيقها.';
                            uploadStatus.style.color = '#4ade80';
                        } else {
                            uploadStatus.textContent = 'فشل الرفع: ' + data.error;
                            uploadStatus.style.color = '#f87171';
                        }
                    } catch (err) {
                        uploadStatus.textContent = 'حدث خطأ أثناء الرفع.';
                        uploadStatus.style.color = '#f87171';
                    }
                };
                reader.readAsDataURL(file);
            });
        }

        updateBackground();
        setTimeout(updateBackground, 100);
    });
</script>

<%- include('partials/footer') %>
