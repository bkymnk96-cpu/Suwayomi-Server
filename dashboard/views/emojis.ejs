<%- include('partials/header') %>
<%- include('partials/sidebar', { activeTab: 'emojis' }) %>

<main class="app-content">
  <div class="content-header emoji-hero">
    <div>
      <h1><i class="fa-solid fa-icons"></i> مركز هوية ZEUS</h1>
      <p>تحكم شامل في الإيموجيات المستخدمة في رسائل البوت، مع معاينة فورية لاكتشاف الإيموجيات المعطّلة مثل الأسماء التي تظهر نصيًا.</p>
    </div>
    <div class="emoji-hero-badge">Gold theme</div>
  </div>

  <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= req.query.success %></div>
  <% } %>
  <% if (typeof req !== 'undefined' && req.query && req.query.error) { %>
    <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation"></i> <%= req.query.error %></div>
  <% } %>

  <section class="glass-panel reveal identity-grid">
    <div>
      <div class="section-title"><i class="fa-solid fa-wand-magic-sparkles"></i> الثيم العام</div>
      <p class="muted-copy">اختيار الثيم يعيد رفع/تحديث Application Emojis ثم يحدّث <code>utils/emojis.json</code> ليتم استبدال الإيموجي تلقائيًا في كل رسالة تستخدم نفس المفتاح.</p>
    </div>
    <form action="/dashboard/admin/emojis/theme" method="POST" class="theme-form">
      <select name="emoji_color" class="glass-input">
        <% ['gold','blue','red','green','purple','pink'].forEach(color => { %>
          <option value="<%= color %>" <%= (settings.emoji_color || 'gold') === color ? 'selected' : '' %>><%= color === 'gold' ? '🟡 الذهبي الافتراضي' : color %></option>
        <% }) %>
      </select>
      <button class="btn btn-primary" type="submit"><i class="fa-solid fa-rotate"></i> تطبيق الثيم</button>
    </form>
  </section>

  <section class="glass-panel reveal">
    <div class="section-title"><i class="fa-solid fa-plus"></i> إضافة أو استبدال إيموجي</div>
    <form action="/dashboard/admin/emojis" method="POST" class="emoji-editor-form">
      <input class="glass-input" name="name" placeholder="key مثل circlecheck أو z_uis" required pattern="[A-Za-z0-9_]{2,32}">
      <input class="glass-input" name="value" placeholder="😀 أو <:name:123456789012345678>" required>
      <button class="btn btn-primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> حفظ/استبدال</button>
    </form>
  </section>

  <section class="glass-panel reveal">
    <div class="section-title"><i class="fa-solid fa-table-cells-large"></i> كل الإيموجيات الحالية (<%= emojis.length %>)</div>
    <input id="emojiSearch" class="glass-input" placeholder="بحث باسم المفتاح أو القيمة..." style="margin-bottom:16px;">
    <div class="emoji-grid" id="emojiGrid">
      <% emojis.forEach(item => { %>
        <article class="emoji-card" data-search="<%= `${item.name} ${item.value}`.toLowerCase() %>">
          <div class="emoji-preview"><%- item.value %></div>
          <div class="emoji-meta">
            <strong><%= item.name %></strong>
            <span class="emoji-status status-<%= item.status %>"><%= item.label %></span>
          </div>
          <form action="/dashboard/admin/emojis" method="POST" class="emoji-inline-form">
            <input type="hidden" name="name" value="<%= item.name %>">
            <input class="glass-input" name="value" value="<%= item.value %>">
            <button class="btn btn-primary btn-sm" title="استبدال"><i class="fa-solid fa-check"></i></button>
          </form>
          <form action="/dashboard/admin/emojis" method="POST">
            <input type="hidden" name="action" value="delete">
            <input type="hidden" name="name" value="<%= item.name %>">
            <button class="btn btn-danger btn-sm" onclick="return confirm('حذف <%= item.name %>؟')"><i class="fa-solid fa-trash"></i> حذف</button>
          </form>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="glass-panel reveal">
    <div class="section-title"><i class="fa-solid fa-message"></i> معاينة رسائل الأوامر</div>
    <p class="muted-copy">هذه فهرسة مباشرة من ملفات الأوامر توضّح مفاتيح الإيموجي المستخدمة ونماذج من الرسائل لتوحيد هوية البوت.</p>
    <div class="command-list">
      <% commands.forEach(cmd => { %>
        <details class="command-card">
          <summary><span><i class="fa-solid fa-terminal"></i> <%= cmd.file %></span><small><%= cmd.emojiKeys.length %> emoji keys</small></summary>
          <div class="command-emojis"><% cmd.emojiKeys.forEach(key => { %><code>{emoji:<%= key %>}</code><% }) %></div>
          <% if (cmd.previews.length) { %><div class="discord-preview"><% cmd.previews.forEach(text => { %><p><%= text %></p><% }) %></div><% } %>
        </details>
      <% }) %>
    </div>
  </section>
</main>

<style>
.emoji-hero { display:flex; justify-content:space-between; gap:18px; align-items:center; }
.emoji-hero-badge { padding:12px 18px; border-radius:999px; background:linear-gradient(135deg,#D4AF37,#8A6A12); color:#100b00; font-weight:900; box-shadow:0 0 30px rgba(212,175,55,.25); }
.identity-grid { display:grid; grid-template-columns: 1fr minmax(260px, 420px); gap:20px; align-items:end; }
.theme-form,.emoji-editor-form { display:grid; grid-template-columns:1fr auto; gap:12px; }
.emoji-editor-form { grid-template-columns: minmax(160px,.35fr) 1fr auto; }
.muted-copy { color:var(--text-muted); line-height:1.8; }
.emoji-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:14px; }
.emoji-card { border:1px solid var(--border); background:linear-gradient(145deg,rgba(255,255,255,.05),rgba(212,175,55,.04)); border-radius:var(--r-md); padding:14px; display:grid; gap:10px; }
.emoji-preview { min-height:42px; font-size:32px; display:flex; align-items:center; justify-content:center; background:#0b0b0b; border-radius:var(--r-sm); overflow:hidden; }
.emoji-meta { display:flex; justify-content:space-between; align-items:center; gap:8px; }
.emoji-status { font-size:.75rem; padding:4px 8px; border-radius:999px; background:#222; color:#ddd; }
.status-broken,.status-unknown { background:rgba(239,68,68,.14); color:#ff8a8a; }
.status-custom { background:rgba(88,101,242,.16); color:#aab2ff; }
.status-unicode { background:rgba(34,197,94,.14); color:#86efac; }
.emoji-inline-form { display:grid; grid-template-columns:1fr auto; gap:8px; }
.btn-sm { padding:8px 10px; }
.command-list { display:grid; gap:10px; }
.command-card { border:1px solid var(--border); border-radius:var(--r-md); background:#101010; padding:12px 14px; }
.command-card summary { cursor:pointer; display:flex; justify-content:space-between; gap:10px; }
.command-emojis { display:flex; gap:8px; flex-wrap:wrap; margin:12px 0; }
.discord-preview { border-right:4px solid #D4AF37; background:#0a0a0a; border-radius:var(--r-sm); padding:10px 14px; color:#ddd; }
@media (max-width: 760px) { .identity-grid,.theme-form,.emoji-editor-form { grid-template-columns:1fr; } .emoji-hero { flex-direction:column; align-items:flex-start; } }
</style>
<script>
document.getElementById('emojiSearch')?.addEventListener('input', event => {
  const value = event.target.value.toLowerCase();
  document.querySelectorAll('.emoji-card').forEach(card => { card.style.display = card.dataset.search.includes(value) ? '' : 'none'; });
});
</script>

<%- include('partials/footer') %>
