<%- include('partials/header') %>
<%- include('partials/sidebar', { activeTab: 'tempvoice' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-microphone-lines"></i> الرومات المؤقتة</h1>
        <p>قم بإعداد نظام الرومات الصوتية المؤقتة التي تُنشأ وتُحذف تلقائياً</p>
    </div>

    <div class="glass-panel reveal">
        <div class="section-title"><i class="fa-solid fa-sliders"></i> إعدادات الروم الأساسية</div>

        <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
            <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= req.query.success %></div>
        <% } %>

        <form action="/dashboard/<%= guild.id %>/tempvoice" method="POST" class="settings-form">
            <div class="grid-form-2">
                <div class="form-group">
                    <label for="master_channel">الروم الرئيسي (Master Voice Channel)</label>
                    <select id="master_channel" name="master_channel" class="glass-input">
                        <option value="">-- اختر روم صوتي --</option>
                        <% channels.forEach(channel => { %>
                            <option value="<%= channel.id %>" <%= settings.master_channel === channel.id ? 'selected' : '' %>>
                                🔊 <%= channel.name %>
                            </option>
                        <% }) %>
                    </select>
                    <small>الروم الصوتي الرئيسي الذي عندما يدخله الأعضاء، يتم إنشاء روم مؤقت لهم</small>
                </div>

                <div class="form-group">
                    <label for="category_id">قسم الرومات (Category)</label>
                    <select id="category_id" name="category_id" class="glass-input">
                        <option value="">-- اختر قسم --</option>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat.id %>" <%= settings.category_id === cat.id ? 'selected' : '' %>>
                                📁 <%= cat.name %>
                            </option>
                        <% }) %>
                    </select>
                    <small>القسم (Category) الذي سيتم إنشاء الرومات الصوتية المؤقتة الجديدة تحته</small>
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-2"><i class="fa-solid fa-floppy-disk"></i> حفظ التغييرات</button>
        </form>
    </div>
</main>

<%- include('partials/footer') %>
