<%- include('partials/header', { title: 'نظام الإدارة' }) %>
<%- include('partials/sidebar', { activeTab: 'admin-system' }) %>
<main class="main-content">
  <div class="page-head reveal"><div><h1><i class="fa-solid fa-crown"></i> نظام الإدارة</h1><p>نقاط، سجلات، إحصائيات، وإعدادات متقدمة لفريق الإدارة.</p></div></div>
  <div class="stats-grid reveal"><div class="stat-card"><i class="fa-solid fa-users"></i><strong><%= profiles.length %></strong><span>أعضاء مسجلون</span></div><div class="stat-card"><i class="fa-solid fa-star"></i><strong><%= profiles.reduce((a,p)=>a+(p.points||0),0) %></strong><span>إجمالي النقاط</span></div><div class="stat-card"><i class="fa-solid fa-clock-rotate-left"></i><strong><%= logs.length %></strong><span>عمليات مسجلة</span></div></div>
  <section class="tickets-layout reveal"><div class="glass-card"><div class="section-title"><i class="fa-solid fa-ranking-star"></i> الأعضاء والنقاط</div><input id="adminSearch" class="glass-input" placeholder="بحث وتصفية..."><table class="data-table"><thead><tr><th>العضو</th><th>النقاط</th><th>إضافة</th><th>خصم</th><th>آخر تحديث</th></tr></thead><tbody><% profiles.forEach(p => { %><tr><td><%= p.userId %></td><td><b><%= p.points||0 %></b></td><td><%= p.totalAdded||0 %></td><td><%= p.totalRemoved||0 %></td><td><%= p.updatedAt ? new Date(p.updatedAt).toLocaleString('ar') : '-' %></td></tr><% }) %></tbody></table></div>
  <div class="glass-card sticky-preview"><div class="section-title"><i class="fa-solid fa-sliders"></i> الإعدادات</div><form method="POST" action="/dashboard/<%= guild.id %>/admin-system/settings" class="settings-form"><label class="toggle-line"><input type="checkbox" name="enabled" <%= settings.enabled ? 'checked' : '' %>> تفعيل النظام</label><label class="toggle-line"><input type="checkbox" name="auto_rewards" <%= settings.auto_rewards ? 'checked' : '' %>> المكافآت التلقائية</label><label>الحد الأقصى للنقاط</label><input class="glass-input" type="number" name="max_points" value="<%= settings.max_points %>"><label>قناة الإشعارات</label><select class="glass-input" name="notify_channel"><option value="">بدون</option><% textChannels.forEach(c=>{ %><option value="<%= c.id %>" <%= settings.notify_channel===c.id?'selected':'' %>><%= c.name %></option><% }) %></select><button class="btn primary">حفظ</button></form></div></section>
  <div class="glass-card reveal"><div class="section-title"><i class="fa-solid fa-clock-rotate-left"></i> سجل العمليات</div><table class="data-table"><thead><tr><th>العضو</th><th>المشرف</th><th>التغيير</th><th>السبب</th><th>الوقت</th></tr></thead><tbody><% logs.slice(0,100).forEach(l=>{ %><tr><td><%= l.userId %></td><td><%= l.moderatorId %></td><td><%= l.amount %></td><td><%= l.reason %></td><td><%= new Date(l.createdAt).toLocaleString('ar') %></td></tr><% }) %></tbody></table></div>
</main><script>document.getElementById('adminSearch')?.addEventListener('input',e=>{const q=e.target.value;document.querySelectorAll('.data-table tbody tr').forEach(r=>r.style.display=r.innerText.includes(q)?'':'none')})</script>
<%- include('partials/footer') %>