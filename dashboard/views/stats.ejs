<%- include('partials/header') %>
<%- include('partials/sidebar', { guild, activeTab: 'stats' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-chart-column"></i> إحصائيات التفاعل (Leaderboard)</h1>
        <p>استعرض متصدري التفاعل بالرسائل، التواجد الصوتي، والريأكشن في سيرفرك</p>
    </div>

    <!-- Overview Counters -->
    <div class="bento-grid cols-4 reveal">
        <div class="metric-card">
            <div class="metric-icon"><i class="fa-solid fa-message text-primary"></i></div>
            <div class="metric-value" data-count="<%= (topMessages && topMessages.length) || 0 %>"><%= (topMessages && topMessages.length) || 0 %></div>
            <div class="metric-label">المتفاعلون بالرسائل</div>
        </div>
        <div class="metric-card">
            <div class="metric-icon"><i class="fa-solid fa-microphone-lines text-success"></i></div>
            <div class="metric-value" data-count="<%= (topVoice && topVoice.length) || 0 %>"><%= (topVoice && topVoice.length) || 0 %></div>
            <div class="metric-label">المتفاعلون بالصوت</div>
        </div>
        <div class="metric-card">
            <div class="metric-icon"><i class="fa-solid fa-face-smile text-warning"></i></div>
            <div class="metric-value" data-count="<%= (topReactions && topReactions.length) || 0 %>"><%= (topReactions && topReactions.length) || 0 %></div>
            <div class="metric-label">المتفاعلون بالريأكشن</div>
        </div>
        <div class="metric-card">
            <div class="metric-icon"><i class="fa-solid fa-users text-muted"></i></div>
            <div class="metric-value" data-count="<%= (topMessages && topMessages.length) || 0 %>"><%= (topMessages && topMessages.length) || 0 %></div>
            <div class="metric-label">إجمالي المسجلين باللوحة</div>
        </div>
    </div>

    <div class="grid-3col reveal" style="animation-delay: 0.1s;">

        <!-- Messages Leaderboard -->
        <div class="glass-panel">
            <div class="section-title"><i class="fa-solid fa-message text-primary"></i> متصدرو الكتابة</div>
            <div class="leaderboard-list">
                <% if (topMessages && topMessages.length > 0) { %>
                    <% topMessages.forEach((user, index) => { %>
                        <div class="list-item">
                            <div class="d-flex align-items-center gap-2">
                                <span class="leader-rank"><%= index + 1 %></span>
                                <span class="leader-user"><i class="fa-solid fa-user"></i> ID: <%= user.userId %></span>
                            </div>
                            <strong class="text-main"><%= user.messages %> رسالة</strong>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state-simple">
                        <p>لا توجد بيانات تفاعل بعد</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Voice Leaderboard -->
        <div class="glass-panel">
            <div class="section-title"><i class="fa-solid fa-microphone-lines text-success"></i> متصدرو الصوت</div>
            <div class="leaderboard-list">
                <% if (topVoice && topVoice.length > 0) { %>
                    <% topVoice.forEach((user, index) => { 
                        const hours = Math.floor(user.voice_xp / 60);
                        const mins = user.voice_xp % 60;
                    %>
                        <div class="list-item">
                            <div class="d-flex align-items-center gap-2">
                                <span class="leader-rank"><%= index + 1 %></span>
                                <span class="leader-user"><i class="fa-solid fa-user"></i> ID: <%= user.userId %></span>
                            </div>
                            <strong class="text-success"><%= hours %>س <%= mins %>د</strong>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state-simple">
                        <p>لا توجد بيانات تفاعل بعد</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Reactions Leaderboard -->
        <div class="glass-panel">
            <div class="section-title"><i class="fa-solid fa-face-smile text-warning"></i> متصدرو التفاعل</div>
            <div class="leaderboard-list">
                <% if (topReactions && topReactions.length > 0) { %>
                    <% topReactions.forEach((user, index) => { %>
                        <div class="list-item">
                            <div class="d-flex align-items-center gap-2">
                                <span class="leader-rank"><%= index + 1 %></span>
                                <span class="leader-user"><i class="fa-solid fa-user"></i> ID: <%= user.userId %></span>
                            </div>
                            <strong class="text-warning"><%= user.reactionsCount || 0 %> تفاعل</strong>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state-simple">
                        <p>لا توجد بيانات تفاعل بعد</p>
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</main>

<style>
.leaderboard-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 10px;
}
.leader-rank {
    font-size: 0.85rem;
    font-weight: 700;
    width: 20px;
    height: 20px;
    background: rgba(255,255,255,0.06);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-2);
}
.leader-user {
    font-size: 0.8rem;
    color: var(--text-2);
}
.empty-state-simple {
    text-align: center;
    padding: 20px 0;
    color: var(--text-3);
    font-size: 0.875rem;
}
</style>

<%- include('partials/footer') %>