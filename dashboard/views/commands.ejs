<%- include('partials/header', { title: 'أوامري' }) %>
<%- include('partials/sidebar', { activeTab: 'aliases' }) %>
<main class="main-content">
  <div class="page-header reveal"><h1><i class="fa-solid fa-terminal"></i> أوامري</h1><p>مركز مرئي لإدارة كل أوامر زيوس، اختصاراتها، الرتب المسموحة والممنوعة، وحالة كل أمر.</p><div class="command-actions"><form action="/dashboard/<%= guild.id %>/aliases/bulk" method="POST"><input type="hidden" name="action" value="enable"><button class="btn btn-primary" type="submit"><i class="fa-solid fa-toggle-on"></i> تفعيل الكل</button></form><form action="/dashboard/<%= guild.id %>/aliases/bulk" method="POST"><input type="hidden" name="action" value="disable"><button class="btn btn-danger" type="submit"><i class="fa-solid fa-toggle-off"></i> تعطيل الكل</button></form></div></div>
  <div class="command-center reveal">
    <section class="command-grid">
      <% const grouped = commands.reduce((a,c)=>{ (a[c.categoryName] ||= []).push(c); return a; }, {}); %>
      <% Object.entries(grouped).forEach(([category, items]) => { %>
        <div class="command-section"><h2><i class="fa-solid fa-layer-group"></i> <%= category %></h2><div class="command-cards">
        <% items.forEach(cmd => { %>
          <a class="command-card <%= selected && selected.name === cmd.name ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/aliases/<%= encodeURIComponent(cmd.name) %>">
            <span class="command-badge"><%= cmd.slash %></span><strong><%= cmd.name %></strong><p><%= cmd.description %></p>
            <div class="command-meta"><span><i class="fa-solid fa-link"></i> <%= cmd.shortcut || 'لا يوجد' %></span><span><i class="fa-solid fa-shield-halved"></i> <%= cmd.disabled ? 'معطل' : 'مفعل' %></span></div>
          </a>
        <% }) %></div></div>
      <% }) %>
    </section>
    <aside class="command-inspector glass-card">
      <% if (selected) { %>
        <h2><i class="fa-solid fa-sliders"></i> تحكم عميق</h2><div class="command-badge large"><%= selected.slash %></div><p><%= selected.description %></p>
        <form action="/dashboard/<%= guild.id %>/aliases" method="POST" class="settings-form">
          <input type="hidden" name="command" value="<%= selected.name %>">
          <div class="form-group"><label>اختصار الأمر</label><input class="glass-input" name="shortcut" value="<%= selected.shortcut %>" placeholder="مثال: باند"></div>
          <div class="form-group"><label>رتب مسموحة فقط</label><select class="glass-input" name="allowRoles" multiple><% roles.forEach(role => { %><option value="<%= role.id %>" <%= selected.allowRoles.includes(role.id) ? 'selected' : '' %>><%= role.name %></option><% }) %></select></div>
          <div class="form-group"><label>رتب ممنوعة</label><select class="glass-input" name="denyRoles" multiple><% roles.forEach(role => { %><option value="<%= role.id %>" <%= selected.denyRoles.includes(role.id) ? 'selected' : '' %>><%= role.name %></option><% }) %></select></div>
          <label class="toggle-row"><input type="checkbox" name="disabled" <%= selected.disabled ? 'checked' : '' %>> تعطيل الأمر مؤقتاً</label>
          <button class="btn btn-primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> حفظ التحكم</button>
        </form>
      <% } else { %>
        <h2><i class="fa-solid fa-wand-magic-sparkles"></i> اختر أمراً</h2><p>اضغط على أي بطاقة لفتح صفحة التحكم العميق الخاصة بها.</p>
      <% } %>
    </aside>
  </div>
</main>
<%- include('partials/footer') %>
