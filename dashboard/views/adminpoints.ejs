<%- include('partials/header', { title: 'نقاط الإدارة' }) %>
<%- include('partials/sidebar', { activeTab: 'admin-points' }) %>
<main class="main-content"><div class="page-header reveal"><h1><i class="fa-solid fa-crown"></i> نقاط الإدارة</h1><p>تحكم موسع بنقاط الإداريين، مديري النظام، الرتب المتتبعة، وسجل المنافسة.</p></div>
<div class="tickets-layout reveal"><section class="glass-card"><div class="section-title"><i class="fa-solid fa-sliders"></i> إعدادات النظام</div><form action="/dashboard/<%= guild.id %>/admin-points" method="POST" class="settings-form"><label class="toggle-row"><input type="checkbox" name="enabled" <%= config.enabled ? 'checked' : '' %>> تفعيل احتساب نقاط الإدارة</label><label class="toggle-row"><input type="checkbox" name="notifyAtMax" <%= config.notifyAtMax ? 'checked' : '' %>> تنبيه عند الوصول للرتب العليا</label><div class="form-group"><label>رتب مديري النقاط</label><select class="glass-input" name="managers" multiple><% roles.forEach(role => { %><option value="<%= role.id %>" <%= config.managers.includes(role.id) ? 'selected' : '' %>><%= role.name %></option><% }) %></select></div><div class="form-group"><label>رتب يتم تتبعها</label><select class="glass-input" name="trackedRoles" multiple><% roles.forEach(role => { %><option value="<%= role.id %>" <%= config.trackedRoles.includes(role.id) ? 'selected' : '' %>><%= role.name %></option><% }) %></select></div><div class="form-group"><label>روم السجل</label><select class="glass-input" name="logChannelId"><option value="">بدون</option><% textChannels.forEach(ch => { %><option value="<%= ch.id %>" <%= config.logChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option><% }) %></select></div><button class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> حفظ الإعدادات</button></form></section><aside class="glass-card sticky-preview"><div class="section-title"><i class="fa-solid fa-ranking-star"></i> لوحة الصدارة</div><% if (leaderboard.length) { %><div class="aliases-list"><% leaderboard.forEach((row,i)=>{ %><div class="alias-item"><div class="alias-item-details"><strong class="text-main">#<%= i+1 %> <@<%= row.userId %>></strong><span><%= row.total || 0 %> نقطة — استلام <%= row.ticketsClaimed || 0 %> / إغلاق <%= row.ticketsClosed || 0 %></span></div></div><% }) %></div><% } else { %><p>لا توجد نقاط مسجلة بعد.</p><% } %></aside></div></main><%- include('partials/footer') %>
