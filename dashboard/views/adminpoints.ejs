<%- include('partials/header', { title: 'نظام الإدارة' }) %>
<%- include('partials/sidebar', { activeTab: 'admin-points' }) %>
<main class="main-content">
  <div class="page-header reveal"><h1><i class="fa-solid fa-crown"></i> نظام الإدارة</h1><p>مركز تحكم شامل لنقاط الإداريين، الترقيات، مديري النظام، التتبع، واللوغ.</p></div>
  <% const totalPoints = leaderboard.reduce((a,b)=>a+(b.total||0),0); const claimed = leaderboard.reduce((a,b)=>a+(b.ticketsClaimed||0),0); const closed = leaderboard.reduce((a,b)=>a+(b.ticketsClosed||0),0); %>
  <div class="management-kpis reveal"><div class="kpi"><span>الحالة</span><strong><%= config.enabled ? 'مفعل' : 'متوقف' %></strong></div><div class="kpi"><span>إجمالي النقاط</span><strong><%= totalPoints %></strong></div><div class="kpi"><span>استلام التذاكر</span><strong><%= claimed %></strong></div><div class="kpi"><span>إغلاق التذاكر</span><strong><%= closed %></strong></div></div>
  <div class="tickets-layout reveal"><section class="glass-card"><div class="section-title"><i class="fa-solid fa-sliders"></i> إعدادات نظام الإدارة</div><form action="/dashboard/<%= guild.id %>/admin-points" method="POST" class="settings-form"><label class="toggle-row"><input type="checkbox" name="enabled" <%= config.enabled ? 'checked' : '' %>> تفعيل احتساب النقاط التلقائي واليدوي</label><label class="toggle-row"><input type="checkbox" name="notifyAtMax" <%= config.notifyAtMax ? 'checked' : '' %>> إرسال تنبيه عند الوصول لترقية</label><div class="form-group"><label>رتب مديري نظام الإدارة</label><select class="glass-input" name="managers" multiple><% roles.forEach(role => { %><option value="<%= role.id %>" <%= config.managers.includes(role.id) ? 'selected' : '' %>><%= role.name %></option><% }) %></select></div><div class="form-group"><label>الرتب التي يتم تتبعها</label><select class="glass-input" name="trackedRoles" multiple><% roles.forEach(role => { %><option value="<%= role.id %>" <%= config.trackedRoles.includes(role.id) ? 'selected' : '' %>><%= role.name %></option><% }) %></select></div><div class="form-group"><label>روم السجل</label><select class="glass-input" name="logChannelId"><option value="">بدون</option><% textChannels.forEach(ch => { %><option value="<%= ch.id %>" <%= config.logChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option><% }) %></select></div><button class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> حفظ الإعدادات</button></form><div class="section-title" style="margin-top:26px"><i class="fa-solid fa-route"></i> خطة الترقيات</div><p class="text-muted">يمكن إدارة الترقيات العميقة من أمر <code>/admin-points</code> التفاعلي داخل ديسكورد، وتظهر هنا فور حفظها.</p><div class="aliases-list"><% (config.ranks || []).sort((a,b)=>a.points-b.points).forEach(rank=>{ %><div class="alias-item"><div class="alias-item-details"><strong class="text-main">&lt;@&amp;<%= rank.roleId %>&gt;</strong><span>عند <%= rank.points %> نقطة</span></div></div><% }) %><% if (!(config.ranks || []).length) { %><p>لا توجد ترقيات محفوظة بعد.</p><% } %></div></section><aside class="glass-card sticky-preview"><div class="section-title"><i class="fa-solid fa-ranking-star"></i> لوحة الصدارة وملفات سريعة</div><% if (leaderboard.length) { %><div class="aliases-list"><% leaderboard.forEach((row,i)=>{ %><div class="alias-item"><div class="alias-item-details"><strong class="text-main">#<%= i+1 %> <@<%= row.userId %>></strong><span><%= row.total || 0 %> نقطة — يدوي <%= row.manual || 0 %> — استلام <%= row.ticketsClaimed || 0 %> — إغلاق <%= row.ticketsClosed || 0 %></span></div></div><% }) %></div><% } else { %><p>لا توجد نقاط مسجلة بعد.</p><% } %></aside></div>
</main><%- include('partials/footer') %>
