<%- include('partials/header') %>
<%- include('partials/sidebar', { activeTab: 'logs' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-clipboard-list"></i> سجلات الأحداث</h1>
        <p>حدد قناة مختلفة لكل نوع من أنواع السجلات، أو اختر تعطيل لتجاهل تسجيل الحدث</p>
    </div>

    <div class="glass-panel reveal">
        <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
            <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= req.query.success %></div>
        <% } %>

        <form action="/dashboard/<%= guild.id %>/logs" method="POST" class="settings-form">
            <div class="section-title"><i class="fa-solid fa-sliders"></i> قنوات السجلات</div>

            <div class="guild-grid mb-2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">

                <div class="form-group log-card reveal" style="animation-delay: 0.05s;">
                    <label for="ban_channel"><i class="fa-solid fa-ban text-danger"></i> سجل الباند (Ban Log)</label>
                    <select id="ban_channel" name="ban_channel" class="glass-input">
                        <option value="" <%= !settings.ban_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.ban_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.08s;">
                    <label for="unban_channel"><i class="fa-solid fa-user-check text-success"></i> سجل فك الباند (Unban Log)</label>
                    <select id="unban_channel" name="unban_channel" class="glass-input">
                        <option value="" <%= !settings.unban_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.unban_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.11s;">
                    <label for="kick_channel"><i class="fa-solid fa-person-walking-arrow-right text-warning"></i> سجل الطرد (Kick Log)</label>
                    <select id="kick_channel" name="kick_channel" class="glass-input">
                        <option value="" <%= !settings.kick_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.kick_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.14s;">
                    <label for="timeout_channel"><i class="fa-solid fa-stopwatch text-warning"></i> سجل التايم أوت (Timeout Log)</label>
                    <select id="timeout_channel" name="timeout_channel" class="glass-input">
                        <option value="" <%= !settings.timeout_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.timeout_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.17s;">
                    <label for="warn_channel"><i class="fa-solid fa-triangle-exclamation text-warning"></i> سجل التحذيرات (Warn Log)</label>
                    <select id="warn_channel" name="warn_channel" class="glass-input">
                        <option value="" <%= !settings.warn_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.warn_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.2s;">
                    <label for="message_delete_channel"><i class="fa-solid fa-trash text-danger"></i> سجل حذف الرسائل</label>
                    <select id="message_delete_channel" name="message_delete_channel" class="glass-input">
                        <option value="" <%= !settings.message_delete_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.message_delete_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.23s;">
                    <label for="message_edit_channel"><i class="fa-solid fa-pen-to-square text-primary"></i> سجل تعديل الرسائل</label>
                    <select id="message_edit_channel" name="message_edit_channel" class="glass-input">
                        <option value="" <%= !settings.message_edit_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.message_edit_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.26s;">
                    <label for="member_join_channel"><i class="fa-solid fa-user-plus text-success"></i> سجل دخول الأعضاء</label>
                    <select id="member_join_channel" name="member_join_channel" class="glass-input">
                        <option value="" <%= !settings.member_join_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.member_join_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.29s;">
                    <label for="member_leave_channel"><i class="fa-solid fa-user-minus text-danger"></i> سجل خروج الأعضاء</label>
                    <select id="member_leave_channel" name="member_leave_channel" class="glass-input">
                        <option value="" <%= !settings.member_leave_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.member_leave_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.32s;">
                    <label for="channel_create_channel"><i class="fa-solid fa-hashtag text-success"></i> سجل إنشاء القنوات</label>
                    <select id="channel_create_channel" name="channel_create_channel" class="glass-input">
                        <option value="" <%= !settings.channel_create_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.channel_create_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.35s;">
                    <label for="channel_delete_channel"><i class="fa-solid fa-hashtag text-danger"></i> سجل حذف القنوات</label>
                    <select id="channel_delete_channel" name="channel_delete_channel" class="glass-input">
                        <option value="" <%= !settings.channel_delete_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.channel_delete_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.38s;">
                    <label for="role_create_channel"><i class="fa-solid fa-shield-halved text-success"></i> سجل إنشاء الرتب</label>
                    <select id="role_create_channel" name="role_create_channel" class="glass-input">
                        <option value="" <%= !settings.role_create_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.role_create_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.41s;">
                    <label for="role_delete_channel"><i class="fa-solid fa-shield-halved text-danger"></i> سجل حذف الرتب</label>
                    <select id="role_delete_channel" name="role_delete_channel" class="glass-input">
                        <option value="" <%= !settings.role_delete_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.role_delete_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group log-card reveal" style="animation-delay: 0.44s;">
                    <label for="nick_change_channel"><i class="fa-solid fa-tag text-primary"></i> سجل تغيير الأسماء المستعارة</label>
                    <select id="nick_change_channel" name="nick_change_channel" class="glass-input">
                        <option value="" <%= !settings.nick_change_channel ? 'selected' : '' %>>بدون / تعطيل</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.nick_change_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

            </div>

            <button type="submit" class="btn btn-primary mt-2"><i class="fa-solid fa-floppy-disk"></i> حفظ قنوات السجلات</button>
        </form>
    </div>
</main>

<%- include('partials/footer') %>
