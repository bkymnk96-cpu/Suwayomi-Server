<%- include('partials/header', { title: 'أوامري' }) %>
<%- include('partials/sidebar', { activeTab: 'aliases' }) %>
<main class="main-content">
  <div class="page-head reveal"><div><h1><i class="fa-solid fa-wand-magic-sparkles"></i> أوامري</h1><p>مركز احترافي لعرض أوامر زيوس، اختصاراتها، صلاحياتها وحالتها.</p></div>
    <div style="display:flex;gap:10px;flex-wrap:wrap"><form method="POST" action="/dashboard/<%= guild.id %>/aliases/toggle-all"><input type="hidden" name="action" value="enable"><button class="btn primary"><i class="fa-solid fa-bolt"></i> تفعيل الكل</button></form><form method="POST" action="/dashboard/<%= guild.id %>/aliases/toggle-all"><input type="hidden" name="action" value="disable"><button class="btn danger"><i class="fa-solid fa-power-off"></i> تعطيل الكل</button></form></div>
  </div>
  <div class="glass-card reveal"><input id="commandSearch" class="glass-input" placeholder="ابحث باسم الأمر أو الاختصار..." style="margin-bottom:16px"><div class="commands-grid">
    <% commands.forEach(cmd => { %>
      <article class="command-card" data-search="<%= (cmd.name + ' ' + cmd.description + ' ' + cmd.shortcut + ' ' + cmd.categoryName).toLowerCase() %>" onclick="openCommandModal('<%= cmd.name %>')">
        <div class="command-card-head"><span class="pill"><%= cmd.categoryName %></span><span class="status <%= cmd.settings.enabled ? 'on' : 'off' %>"><%= cmd.settings.enabled ? 'مفعل' : 'معطل' %></span></div>
        <h3><%= cmd.arabicName %></h3><code><%= cmd.slash %></code><p><%= cmd.description %></p><small><i class="fa-solid fa-link"></i> الاختصار: <b><%= cmd.shortcut || 'لا يوجد' %></b></small>
      </article>
      <dialog class="command-modal" id="modal-<%= cmd.name %>"><form method="POST" action="/dashboard/<%= guild.id %>/aliases" class="modal-box"><input type="hidden" name="command" value="<%= cmd.name %>"><button type="button" class="modal-close" onclick="closeCommandModal('<%= cmd.name %>')">×</button><h2><i class="fa-solid fa-terminal"></i> <%= cmd.slash %></h2><label>اختصار الأمر</label><input class="glass-input" name="shortcut" value="<%= cmd.shortcut %>" placeholder="مثال: باند"><label class="toggle-line"><input type="checkbox" name="enabled" <%= cmd.settings.enabled ? 'checked' : '' %> <%= cmd.core ? 'disabled' : '' %>> تفعيل الأمر <%= cmd.core ? '(أساسي لا يعطل)' : '' %></label><div class="two-col"><div><label>Allow roles</label><select class="glass-input" name="allowRoles" multiple><% roles.forEach(r => { %><option value="<%= r.id %>" <%= (cmd.settings.allowRoles||[]).includes(r.id) ? 'selected' : '' %>><%= r.name %></option><% }) %></select></div><div><label>Deny roles</label><select class="glass-input" name="denyRoles" multiple><% roles.forEach(r => { %><option value="<%= r.id %>" <%= (cmd.settings.denyRoles||[]).includes(r.id) ? 'selected' : '' %>><%= r.name %></option><% }) %></select></div></div><button class="btn primary" style="margin-top:14px">حفظ التحكم العميق</button></form></dialog>
    <% }) %>
  </div></div>
</main>
<script>function openCommandModal(n){document.getElementById('modal-'+n)?.showModal()}function closeCommandModal(n){document.getElementById('modal-'+n)?.close()}document.getElementById('commandSearch')?.addEventListener('input',e=>{const q=e.target.value.toLowerCase();document.querySelectorAll('.command-card').forEach(c=>c.style.display=c.dataset.search.includes(q)?'block':'none')});</script>
<%- include('partials/footer') %>