<%- include('partials/header') %>
<%- include('partials/sidebar', { activeTab: 'home' }) %>

<main class="app-content">

    <!-- Hero Section -->
    <div class="hero-section reveal">
        <% if (bot) { %>
            <div class="hero-avatar-wrap">
                <img src="<%= bot.displayAvatarURL({ size: 256 }) %>" alt="<%= bot.username %>">
                <span class="hero-status"></span>
            </div>
            <h1 class="hero-name"><%= bot.username %></h1>
        <% } else { %>
            <div class="hero-avatar-wrap hero-avatar-placeholder">
                <i class="fa-solid fa-robot"></i>
            </div>
            <h1 class="hero-name">E-246 Bot</h1>
        <% } %>
        <p class="hero-sub">التجربة المثالية والشاملة لإدارة سيرفرك باحترافية</p>

        <div class="hero-actions">
            <% if (!user) { %>
                <a href="/auth/login" class="btn btn-primary btn-large hero-btn">
                    <i class="fa-brands fa-discord"></i> ابدأ الآن
                </a>
            <% } else { %>
                <a href="/dashboard" class="btn btn-primary btn-large hero-btn">
                    <i class="fa-solid fa-server"></i> لوحة التحكم
                </a>
            <% } %>
        </div>
    </div>

    <!-- Stats Cards -->
    <% if (typeof stats !== 'undefined') { %>
    <div class="bento-grid cols-4 reveal" style="max-width: 900px; margin: 0 auto 40px;">

        <div class="metric-card text-center">
            <div class="metric-icon" style="margin: 0 auto 12px;">
                <i class="fa-solid fa-server"></i>
            </div>
            <div class="metric-value" data-count="<%= stats.totalGuilds %>"><%= stats.totalGuilds %></div>
            <div class="metric-label">إجمالي السيرفرات</div>
        </div>

        <div class="metric-card text-center">
            <div class="metric-icon" style="margin: 0 auto 12px;">
                <i class="fa-solid fa-users"></i>
            </div>
            <div class="metric-value" data-count="<%= stats.totalUsers %>"><%= stats.totalUsers %></div>
            <div class="metric-label">إجمالي الأعضاء</div>
        </div>

        <div class="metric-card text-center">
            <div class="metric-icon" style="margin: 0 auto 12px;">
                <i class="fa-solid fa-microchip"></i>
            </div>
            <div class="metric-value" style="font-size: 1.3rem; direction: ltr;"><%= stats.ram %></div>
            <div class="metric-label">استهلاك الذاكرة</div>
        </div>

        <div class="metric-card text-center">
            <div class="metric-icon" style="margin: 0 auto 12px;">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </div>
            <div class="metric-value" style="font-size: 1.2rem; direction: ltr;"><%= stats.uptime %></div>
            <div class="metric-label">مدة التشغيل</div>
        </div>

    </div>
    <% } %>

</main>

<style>
/* Hero Section */
.hero-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 48px 24px 52px;
}

.hero-avatar-wrap {
    position: relative;
    width: 100px;
    height: 100px;
    margin-bottom: 20px;
}
.hero-avatar-wrap img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid var(--border);
    display: block;
}
.hero-avatar-placeholder {
    background: var(--bg-3);
    border-radius: 50%;
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: var(--text-2);
}
.hero-status {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 18px;
    height: 18px;
    background: var(--success);
    border-radius: 50%;
    border: 3px solid var(--bg-0);
    animation: hero-pulse 2.5s ease-in-out infinite;
}

@keyframes hero-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5); }
    50%       { box-shadow: 0 0 0 6px rgba(74, 222, 128, 0); }
}

.hero-name {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--text-1);
    margin-bottom: 10px;
}

.hero-sub {
    color: var(--text-2);
    font-size: 0.95rem;
    max-width: 400px;
    line-height: 1.6;
    margin-bottom: 28px;
}

.hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
.hero-btn { min-width: 180px; }

@media (max-width: 768px) {
    .hero-section { padding: 32px 16px 36px; }
    .hero-name { font-size: 1.5rem; }
}
</style>

<%- include('partials/footer') %>