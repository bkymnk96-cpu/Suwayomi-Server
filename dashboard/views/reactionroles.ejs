<%- include('partials/header') %>
<%- include('partials/sidebar', { guild, activeTab: 'reactionroles' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-masks-theater"></i> التفاعل بالرتب (Reaction Roles)</h1>
        <p>أنشئ لوحات أزرار أو قوائم منسدلة ليحصل الأعضاء على رتبهم المفضلة بضغطة زر</p>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="tickets-layout reveal">
        <!-- settings form -->
        <div class="glass-panel">
            <form action="/dashboard/<%= guild.id %>/reactionroles" method="POST" id="rrForm">
                <div class="section-title"><i class="fa-solid fa-paintbrush"></i> ١. تصميم لوحة الرتب</div>
                
                <div class="form-group mt-2">
                    <label>عنوان الإمبيد الرئيسي</label>
                    <input type="text" name="title" id="title" class="glass-input" value="<%= settings.panel_data.title || 'اختر رتبك المفضلة' %>" required>
                </div>
                <div class="form-group">
                    <label>وصف الإمبيد</label>
                    <textarea name="description" id="description" class="glass-input" rows="3" required><%= settings.panel_data.description || 'اضغط على الأزرار المخصصة بالأسفل للحصول على رتبتك.' %></textarea>
                </div>
                <div class="grid-form-2">
                    <div class="form-group">
                        <label>لون الإمبيد</label>
                        <input type="color" name="color" id="color" class="glass-input" style="height: 40px; padding: 4px; cursor: pointer;" value="<%= settings.panel_data.color || '#5865F2' %>" data-rr-color>
                    </div>
                    <div class="form-group">
                        <label>رابط الصورة المصغرة (Thumbnail)</label>
                        <input type="url" name="thumbnail" id="thumbnail" class="glass-input" placeholder="https://example.com/thumb.png" value="<%= settings.panel_data.thumbnail || '' %>">
                    </div>
                </div>
                <div class="form-group">
                    <label>رابط الصورة الكبيرة (Banner Image)</label>
                    <input type="url" name="image" id="image" class="glass-input" placeholder="https://example.com/banner.png" value="<%= settings.panel_data.image || '' %>">
                </div>

                <hr class="divider">

                <div class="section-title"><i class="fa-solid fa-layer-group"></i> ٢. نوع المكوّن التفاعلي</div>
                <div class="form-group mt-2">
                    <label>عرض الرتب على شكل:</label>
                    <select name="comp_type" id="comp_type" class="glass-input">
                        <option value="button" <%= settings.panel_data.comp_type === 'button' ? 'selected' : '' %>>🔘 أزرار منفصلة (Buttons)</option>
                        <option value="select" <%= settings.panel_data.comp_type === 'select' ? 'selected' : '' %>>🗂️ قائمة منسدلة واحدة (Select Menu)</option>
                    </select>
                </div>

                <hr class="divider">

                <div class="setting-row" style="margin-bottom:12px;">
                    <div class="section-title" style="margin:0;"><i class="fa-solid fa-list-check"></i> ٣. قائمة الرتب المعروضة</div>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="addRoleRow()"><i class="fa-solid fa-plus"></i> إضافة رتبة</button>
                </div>
                
                <div id="rolesContainer" style="display:flex; flex-direction:column; gap:10px; margin-bottom:20px;"></div>
                <input type="hidden" name="roles_data" id="roles_data">

                <hr class="divider">

                <div class="section-title"><i class="fa-solid fa-paper-plane"></i> ٤. نشر لوحة الرتب</div>
                <div class="form-group mt-2">
                    <label>قناة نشر اللوحة</label>
                    <select name="panel_channel" id="panel_channel" class="glass-input">
                        <option value="">-- اختر القناة --</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>"># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group d-flex align-items-center gap-2 mt-2 mb-3">
                    <input type="checkbox" name="send_panel" id="send_panel" value="yes" style="width:18px;height:18px;accent-color:#fff;cursor:pointer;">
                    <label for="send_panel" class="cursor-pointer" style="margin:0; font-weight:500; font-size:0.85rem;">إرسال / تحديث اللوحة في القناة الآن</label>
                </div>

                <button type="submit" class="btn btn-primary btn-large btn-block" onclick="prepareSubmit(event)">
                    <i class="fa-solid fa-floppy-disk"></i> حفظ ونشر لوحة الرتب
                </button>
            </form>
        </div>

        <!-- live preview -->
        <div class="sticky-preview">
            <div class="glass-panel">
                <div class="section-title"><i class="fa-solid fa-eye"></i> معاينة مباشرة</div>

                <div class="discord-preview-container" style="background:#0c0c0c; border: 1px solid var(--border); border-radius: var(--r-md); padding:16px;">
                    <div class="discord-embed" style="background-color:#141414; max-width:100%; border-radius:var(--r-sm); border:1px solid var(--border); border-right:4px solid #5865F2; border-left:none; padding:16px;">
                        <div class="d-flex gap-2">
                            <img src="<%= client.user.displayAvatarURL() %>" style="width:32px; height:32px; border-radius:50%; border:1px solid var(--border);">
                            <div class="flex-grow-1" style="min-width:0;">
                                <div class="d-flex align-items-center gap-sm mb-1">
                                    <span style="color:#fff; font-weight:600; font-size:0.85rem;"><%= client.user.username %></span>
                                    <span class="bot-tag-preview">BOT</span>
                                </div>
                                <div id="preview-embed" style="border-right:4px solid #5865F2; border-left:none; background:#0a0a0a; padding:12px; border-radius:var(--r-sm); border:1px solid var(--border); display:flex; gap:16px; justify-content:space-between;">
                                    <div class="flex-grow-1" style="min-width:0;">
                                        <div id="preview-title" style="color:#fff; font-weight:700; font-size:0.95rem; margin-bottom:6px;"></div>
                                        <div id="preview-desc" style="color:var(--text-2); font-size:0.85rem; line-height:1.5; white-space:pre-wrap;"></div>
                                        <img id="preview-image" src="" style="max-width:100%; max-height:200px; border-radius:4px; margin-top:10px; object-fit:cover; display:none;">
                                    </div>
                                    <img id="preview-thumb" src="" style="width:60px; height:60px; border-radius:4px; object-fit:contain; display:none; flex-shrink:0;">
                                </div>
                                <div id="preview-components" class="mt-2 d-flex flex-wrap gap-sm"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- native react roles table -->
    <hr class="divider">
    <div class="content-header reveal" style="animation-delay: 0.15s;">
        <h2><i class="fa-solid fa-terminal"></i> رتب تفاعلية مضافة عبر الأوامر المباشرة</h2>
        <p>الرتب التفاعلية التي تم ربطها برسائل عادية مسبقاً داخل الديسكورد مباشرة عبر أمر <code>/reactrole</code></p>
    </div>

    <div class="glass-panel reveal" style="animation-delay: 0.2s;">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>معرّف الرسالة (Message ID)</th>
                        <th>الإيموجي</th>
                        <th>الرتبة الممنوحة</th>
                        <th style="text-align: left;">إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof nativeReactionRoles !== 'undefined' && nativeReactionRoles.length > 0) { %>
                        <% nativeReactionRoles.forEach(rr => { %>
                            <tr>
                                <td><code><%= rr.messageId %></code></td>
                                <td><%= rr.emoji %></td>
                                <td>
                                    <% const roleObj = roles.find(r => r.id === rr.roleId); %>
                                    <span class="role-badge">@<%= roleObj ? roleObj.name : rr.roleId %></span>
                                </td>
                                <td style="text-align: left;">
                                    <form action="/dashboard/<%= guild.id %>/reactionroles/delete" method="POST" style="display:inline; margin:0;">
                                        <input type="hidden" name="messageId" value="<%= rr.messageId %>">
                                        <input type="hidden" name="emoji" value="<%= rr.emoji %>">
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('هل أنت متأكد من إلغاء هذه الرتبة التفاعلية؟');">
                                            <i class="fa-solid fa-trash"></i> حذف
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted" style="padding:20px;">لا توجد رتب تفاعلية مضافة عبر الأوامر في هذا السيرفر حالياً</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<style>
.role-row {
    position: relative;
    background: rgba(255,255,255,0.025);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 14px;
    padding-left: 40px;
    transition: border-color var(--t-fast);
}
.role-row:hover {
    border-color: var(--border-hover);
}
.bot-tag-preview {
    background: #5865F2;
    color: #fff;
    font-size: 0.6rem;
    padding: 1px 4px;
    border-radius: 3px;
    font-weight: 700;
}
.role-badge {
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
}
</style>

<script>
    const existingRoles = <%- JSON.stringify(settings.roles_data || []) %>;
    const serverRoles = <%- JSON.stringify(roles) %>;
</script>

<script>
    const rolesContainer = document.getElementById('rolesContainer');
    let roleCount = 0;

    function addRoleRow(data = null) {
        if (roleCount >= 25) {
            alert('الحد الأقصى هو 25 رتبة فقط بسبب قيود مكونات ديسكورد.');
            return;
        }

        const div = document.createElement('div');
        div.className = "role-row";

        let roleOptions = '<option value="">-- اختر الرتبة --</option>';
        serverRoles.forEach(r => {
            const selected = (data && data.roleId === r.id) ? 'selected' : '';
            roleOptions += `<option value="${r.id}" ${selected}>@${r.name}</option>`;
        });

        div.innerHTML = `
            <button type="button" onclick="this.parentElement.remove(); roleCount--; updatePreview();" style="position: absolute; top: 12px; left: 12px; background: transparent; border: none; color: var(--danger); cursor: pointer; font-size: 1rem;"><i class="fa-solid fa-trash"></i></button>
            <div class="form-group" style="margin-bottom: 8px;">
                <label style="font-size: 0.85rem; font-weight:600;">الرتبة الممنوحة</label>
                <select class="glass-input role-select" required onchange="updatePreview()">
                    ${roleOptions}
                </select>
            </div>
            <div class="grid-form-2">
                <div class="form-group" style="margin-bottom: 0;">
                    <label style="font-size: 0.85rem; font-weight:600;">إيموجي الزر (اختياري)</label>
                    <input type="text" class="glass-input role-emoji" placeholder="مثال: 🔴" value="${data ? data.emoji : ''}" oninput="updatePreview()">
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                    <label style="font-size: 0.85rem; font-weight:600;">عنوان الزر/الخيار</label>
                    <input type="text" class="glass-input role-label" placeholder="مثال: رتبة اليوتيوبرز" value="${data ? data.label : 'احصل على الرتبة'}" oninput="updatePreview()">
                </div>
            </div>
        `;
        rolesContainer.appendChild(div);
        roleCount++;
        updatePreview();
    }

    if (existingRoles.length > 0) {
        existingRoles.forEach(r => addRoleRow(r));
    } else {
        addRoleRow();
    }

    function prepareSubmit(e) {
        const rows = document.querySelectorAll('.role-row');
        const rolesData = [];
        rows.forEach(row => {
            const roleId = row.querySelector('.role-select').value;
            const emoji = row.querySelector('.role-emoji').value.trim();
            const label = row.querySelector('.role-label').value.trim();
            if (roleId) rolesData.push({ roleId, emoji, label });
        });
        if (rolesData.length === 0) {
            e.preventDefault();
            alert('يجب إضافة رتبة واحدة على الأقل للاستمارة');
            return;
        }
        document.getElementById('roles_data').value = JSON.stringify(rolesData);
    }

    const inputs = ['title', 'description', 'color', 'thumbnail', 'image', 'comp_type'];
    inputs.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', updatePreview);
    });

    function updatePreview() {
        const title = document.getElementById('title').value;
        const desc = document.getElementById('description').value;
        const color = document.getElementById('color').value;
        const thumb = document.getElementById('thumbnail').value;
        const img = document.getElementById('image').value;
        const compType = document.getElementById('comp_type').value;

        document.getElementById('preview-embed').style.borderRightColor = color;
        document.getElementById('preview-title').innerText = title;
        document.getElementById('preview-desc').innerText = desc;

        const pThumb = document.getElementById('preview-thumb');
        if (thumb) { pThumb.src = thumb; pThumb.style.display = 'block'; } else { pThumb.style.display = 'none'; }

        const pImg = document.getElementById('preview-image');
        if (img) { pImg.src = img; pImg.style.display = 'block'; } else { pImg.style.display = 'none'; }

        const compContainer = document.getElementById('preview-components');
        compContainer.innerHTML = '';
        const rows = document.querySelectorAll('.role-row');
        
        if (compType === 'button') {
            rows.forEach(row => {
                const emoji = row.querySelector('.role-emoji').value.trim();
                const label = row.querySelector('.role-label').value.trim();
                const btn = document.createElement('div');
                btn.style.cssText = "background: #5865F2; color: #fff; padding: 6px 12px; border-radius: 4px; font-weight: 500; font-size: 0.8rem; display: flex; align-items: center; gap: 6px; cursor: default; margin-bottom: 4px;";
                btn.innerHTML = `${emoji ? `<span>${emoji}</span>` : ''} <span>${label || 'احصل على الرتبة'}</span>`;
                compContainer.appendChild(btn);
            });
        } else if (rows.length > 0) {
            const sel = document.createElement('div');
            sel.style.cssText = "width: 100%; background: #2b2d31; color: #dbdee1; padding: 8px 12px; border-radius: 4px; border: 1px solid #3e4047; display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem;";
            sel.innerHTML = `<span>اختر رتبك المفضلة...</span> <i class="fa-solid fa-chevron-down" style="font-size: 0.75rem; color:#b5bac1;"></i>`;
            compContainer.appendChild(sel);
        }
    }

    updatePreview();
</script>

<%- include('partials/footer') %>
